{
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/workspace/**", "destination": "/workspace/index.html" },
      { "source": "/admin", "destination": "/admin/index.html" },
      { "source": "/admin/**", "destination": "/admin/index.html" }
    ],
    "headers": [
      {
        "source": "/apps/**",
        "headers": [
          { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
        ]
      },
      {
        "source": "/apps/**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
        ]
      },
      {
        "source": "/workspace/**",
        "headers": [
          { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
        ]
      },
      {
        "source": "/admin/**",
        "headers": [
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
        ]
      },
      {
        "source": "**",
        "headers": [
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
        ]
      },
      {
        "source": "**/*.@(js|css|html)",
        "headers": [{ "key": "Cache-Control", "value": "max-age=3600" }]
      },
      {
        "source": "/apps/delivery/project_planner_helpers.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
        ]
      }
    ],
    "redirects": [
      { "source": "/portal.html", "destination": "/apps/public/portal.html", "type": 301 },
      { "source": "/client_intake.html", "destination": "/apps/public/client_intake.html", "type": 301 },
      { "source": "/core_workspace_app.html", "destination": "/workspace/", "type": 301 },
      { "source": "/admin_console.html", "destination": "/admin/portals", "type": 301 },
      { "source": "/project_planner.html", "destination": "/apps/delivery/project_planner.html", "type": 301 },
      { "source": "/crm_pipeline.html", "destination": "/apps/operations/crm_pipeline.html", "type": 301 },
      { "source": "/policy_studio.html", "destination": "/apps/operations/policy_studio.html", "type": 301 },
      { "source": "/workflow_builder.html", "destination": "/apps/operations/workflow_builder.html", "type": 301 },
      { "source": "/firm_analytics_dashboard.html", "destination": "/apps/analytics/firm_analytics_dashboard.html", "type": 301 },
      { "source": "/intake_center.html", "destination": "/admin/intake", "type": 301 },
      { "source": "/contract_ledger.html", "destination": "/apps/public/contract_sign.html", "type": 301 },
      { "source": "/core_master_admin.html", "destination": "/admin/master", "type": 301 },
      { "source": "/admin/legacy/index.html", "destination": "/admin/", "type": 301 },
      { "source": "/admin/legacy/intake_center.html", "destination": "/admin/intake", "type": 301 },
      { "source": "/admin/legacy/admin_console.html", "destination": "/admin/portals", "type": 301 },
      { "source": "/admin/legacy/core_master_admin.html", "destination": "/admin/master", "type": 301 },
      { "source": "/admin/legacy/core_workspace_app.html", "destination": "/workspace/", "type": 301 },
      { "source": "/admin/legacy/contract_ledger.html", "destination": "/apps/public/contract_sign.html", "type": 301 }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": ["node_modules", ".git", "firebase-debug.log", "firebase-debug.*.log", "*.local"],
      "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"]
    }
  ],
  "emulators": {
    "auth": { "port": 9099 },
    "functions": { "port": 5001 },
    "firestore": { "port": 8080 },
    "storage": { "port": 9199 },
    "hosting": { "port": 5000 },
    "ui": { "enabled": true }
  }
}
