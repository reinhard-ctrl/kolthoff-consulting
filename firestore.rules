rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAnonymous() {
      return isAuthenticated() &&
        request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    /** Kolthoff admin passcode session or custom claim */
    function isKolthoffAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == 'kolthoff_admin' ||
        exists(/databases/$(database)/documents/artifacts/kolthoff-admin-app/public/data/admin_sessions/$(request.auth.uid))
      );
    }

    /** Staff: kolthoff admin session, Workspace SSO/claims, or tenant members — not anonymous */
    function isKolthoffStaffEmail() {
      return isAuthenticated() &&
        request.auth.token.email is string &&
        request.auth.token.email.matches('.*@kolthoff-consulting\\.com$');
    }

    function hasTenantStaffClaim() {
      return isAuthenticated() &&
        request.auth.token.tenantId is string &&
        request.auth.token.role != 'portal_client';
    }

    function isStaffMember() {
      return isKolthoffAdmin() || isKolthoffStaffEmail() || hasTenantStaffClaim();
    }

    function isTenantMember(tenantId) {
      return isAuthenticated() && (
        isKolthoffAdmin() ||
        request.auth.token.tenantId == tenantId
      );
    }

    function isTenantAdmin(tenantId) {
      return isAuthenticated() && (
        isKolthoffAdmin() ||
        (request.auth.token.tenantId == tenantId && request.auth.token.role == 'admin')
      );
    }

    function isPortalClient() {
      return isAuthenticated() && request.auth.token.role == 'portal_client';
    }

    function isPortalClientFor(clientId) {
      return isPortalClient() && request.auth.token.accessCode == clientId;
    }

    function crmShareLinkEnabled(token) {
      return exists(/databases/$(database)/documents/artifacts/kolthoff-admin-app/public/data/crm_share_links/$(token)) &&
        get(/databases/$(database)/documents/artifacts/kolthoff-admin-app/public/data/crm_share_links/$(token)).data.enabled == true;
    }

    /** E-sign client link — ledger doc must exist and be sent or already signed */
    function contractLedgerPath(profileId) {
      let contractId = 'contract-' + profileId;
      return /databases/$(database)/documents/artifacts/kolthoff-admin-app/public/data/contracts_ledger/$(contractId);
    }

    function isActiveClientContract(profileId) {
      return exists(contractLedgerPath(profileId)) &&
        get(contractLedgerPath(profileId)).data.status in ['sent', 'signed'];
    }

    function isClientContractSigningUpdate() {
      return resource.data.status == 'sent' &&
        request.resource.data.status == 'signed' &&
        request.resource.data.signedAt is string &&
        request.resource.data.signedBy is string &&
        request.resource.data.auditTrail is list;
    }

    // Admin passcodes — single-doc get only (doc id is the secret); no listing
    match /artifacts/{tenantId}/public/data/admin_credentials/{code} {
      allow get: if isAuthenticated();
      allow list: if false;
      allow write: if isKolthoffAdmin();
    }

    function isGoogleStaffSignIn() {
      return isKolthoffStaffEmail() &&
        request.auth.token.firebase.sign_in_provider == 'google.com';
    }

    // Google SSO provisioning — Firestore trigger sets claims (no public Cloud Function required)
    match /artifacts/kolthoff-admin-app/public/data/staff_sso_requests/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow create: if isAuthenticated() && request.auth.uid == uid &&
        isGoogleStaffSignIn() &&
        request.resource.data.status == 'pending' &&
        request.resource.data.email == request.auth.token.email;
      allow update: if isAuthenticated() && request.auth.uid == uid &&
        isGoogleStaffSignIn() &&
        resource.data.status == 'error' &&
        request.resource.data.status == 'pending';
      allow delete: if isAuthenticated() && request.auth.uid == uid;
    }

    // Admin console session after passcode verify (no public Cloud Function required)
    match /artifacts/kolthoff-admin-app/public/data/admin_sessions/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow create, update: if isAuthenticated() && request.auth.uid == uid &&
        request.resource.data.role == 'kolthoff_admin' &&
        request.resource.data.passcodeVerified is string &&
        exists(/databases/$(database)/documents/artifacts/kolthoff-admin-app/public/data/admin_credentials/$(request.resource.data.passcodeVerified));
      allow delete: if isAuthenticated() && request.auth.uid == uid;
    }

    // Workspace login directory — staff only
    match /artifacts/kolthoff-admin-app/public/data/core_users/{userId} {
      allow read: if isStaffMember();
      allow write: if isKolthoffAdmin();
    }

    // Firm internal data — staff only (blocks anonymous CRM/planner scraping)
    match /artifacts/kolthoff-admin-app/public/data/crm_share_links/{token} {
      allow get: if request.auth != null;
      allow list: if false;
      allow create, update, delete: if isStaffMember();
    }

    match /artifacts/kolthoff-admin-app/public/data/crm_public_view/{token} {
      allow read: if request.auth != null && crmShareLinkEnabled(token);
      allow write: if isStaffMember();
    }

    // Client e-sign — scoped read for sent/signed contracts (incognito uses anonymous auth)
    match /artifacts/kolthoff-admin-app/public/data/workbook_profiles/{profileId} {
      allow read: if isStaffMember() || (isAuthenticated() && isActiveClientContract(profileId));
      allow write: if isStaffMember();
    }

    match /artifacts/kolthoff-admin-app/public/data/contracts_ledger/{contractId} {
      allow read: if isStaffMember() || (
        isAuthenticated() && resource.data.status in ['sent', 'signed']
      );
      allow create, delete: if isStaffMember();
      allow update: if isStaffMember() || (isAuthenticated() && isClientContractSigningUpdate());
    }

    match /artifacts/kolthoff-admin-app/public/data/{collection}/{docId} {
      allow read, write: if isStaffMember();
    }

    // Tenant-scoped collections
    match /artifacts/{tenantId}/public/data/{collection}/{docId} {
      allow read, write: if isTenantMember(tenantId);
      allow delete: if isTenantAdmin(tenantId);

      allow create: if collection == 'core_audit_log' && isTenantMember(tenantId);
      allow read: if collection == 'core_audit_log' && isTenantAdmin(tenantId);
    }

    // Client portal — doc id is the access code secret (same pattern as admin_credentials)
    match /artifacts/{tenantId}/public/data/clients/{clientId} {
      allow get: if isStaffMember() || isPortalClientFor(clientId) || isAuthenticated();
      allow list: if isStaffMember();
      allow write: if isKolthoffAdmin();
    }
  }
}
