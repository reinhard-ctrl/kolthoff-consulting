rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAnonymous() {
      return isAuthenticated() &&
        request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    function isKolthoffAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == 'kolthoff_admin' ||
        firestore.exists(/databases/(default)/documents/artifacts/kolthoff-admin-app/public/data/admin_sessions/$(request.auth.uid)) ||
        firestore.exists(/databases/(default)/documents/artifacts/agency-ops-demo/public/data/admin_sessions/$(request.auth.uid))
      );
    }

    function isTenantMember(tenantId) {
      return isAuthenticated() && (
        isKolthoffAdmin() ||
        request.auth.token.tenantId == tenantId
      );
    }

    function isStaffMember() {
      return isKolthoffAdmin() || (
        isAuthenticated() &&
        request.auth.token.email is string &&
        request.auth.token.email.matches('.*@kolthoff-consulting\\.com$')
      ) || (
        isAuthenticated() &&
        request.auth.token.tenantId is string &&
        request.auth.token.role != 'portal_client'
      );
    }

    function isPortalClient() {
      return isAuthenticated() && request.auth.token.role == 'portal_client';
    }

    function isPortalClientFor(clientId) {
      return isPortalClient() && request.auth.token.accessCode == clientId;
    }

    function clientPortalExists(clientId) {
      return firestore.exists(/databases/(default)/documents/artifacts/kolthoff-admin-app/public/data/clients/$(clientId));
    }

    function isAnonymousPortalFor(clientId) {
      return isAnonymous() && clientPortalExists(clientId);
    }

    match /artifacts/{tenantId}/files/{clientId}/{filename} {
      allow read: if isStaffMember() || isPortalClientFor(clientId) || isAnonymousPortalFor(clientId);
      allow write: if isStaffMember() || (
        (isPortalClientFor(clientId) || isAnonymousPortalFor(clientId)) &&
        request.resource.size < 25 * 1024 * 1024 &&
        request.resource.contentType.matches('application/.*|image/.*|text/.*')
      );
      allow delete: if isKolthoffAdmin();
    }
  }
}
