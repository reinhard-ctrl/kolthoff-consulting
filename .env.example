# Firebase service account JSON — add in GitHub Secrets as FIREBASE_SERVICE_ACCOUNT
# App Check (Package P5) — reCAPTCHA v3 site key; injected at build into admin/workspace/HTML apps
RECAPTCHA_SITE_KEY=
# Marketing explainer — unlisted YouTube video ID; injected into homepage at build
EXPLAINER_YOUTUBE_ID=
# Optional local App Check debug: ?appCheckDebug=TOKEN on admin/workspace URLs
