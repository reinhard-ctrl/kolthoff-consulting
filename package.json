{
  "name": "kolthoff-consulting",
  "version": "2.0.0",
  "private": true,
  "description": "Kolthoff Consulting Operations Suite — Firebase platform",
  "scripts": {
    "build": "node scripts/build.js",
    "build:workspace": "npm run build --prefix workspace",
    "build:admin": "npm run build --prefix admin",
    "dev:workspace": "npm run dev --prefix workspace",
    "dev:admin": "npm run dev --prefix admin",
    "test:rules": "npm run test --prefix tests",
    "provision:m102-form": "node scripts/provision-m102-feedback-form.mjs",
    "deploy": "npm run build && firebase deploy",
    "deploy:hosting": "npm run build && firebase deploy --only hosting",
    "serve:hosting": "npm run build && firebase emulators:start --only hosting",
    "deploy:rules": "firebase deploy --only firestore:rules,storage",
    "emulators": "firebase emulators:start"
  },
  "dependencies": {
    "firebase-tools": "^13.29.1"
  },
  "devDependencies": {
    "googleapis": "^144.0.0"
  },
  "workspaces": [
    "workspace",
    "admin",
    "functions",
    "tests"
  ]
}
